{
  "name": "textfromimage-extension",
  "version": "0.1.0",
  "description": "TextFromImage — extract text from images locally (web and files). By AI4Context.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "icons": "node scripts/build-icons.mjs",
    "tesseract": "node scripts/copy-tesseract-assets.mjs",
    "prebuild": "npm run icons && npm run tesseract",
    "build": "vite build",
    "pack": "npm run build && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-zip.ps1",
    "preview": "vite preview"
  },
  "license": "ISC",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tesseract.js": "^6.0.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
